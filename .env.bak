APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:WwR95d/d02ig6DzTY+JfyxaOM6OHBwObXSLPwm8jJek=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=my_ecommerce
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log

# =========================================================
# CACHING (Req 6) — toggle driver for the before/after benchmark
# =========================================================
# CACHE_DRIVER options: redis (cache on), array (cache off — baseline)
CACHE_DRIVER=redis
# CACHE_DRIVER=array

FILESYSTEM_DISK=local
# Req 3 queue backend. database = jobs visible in `jobs` table (academic demo);
# redis = far faster dispatch (removes 2 MySQL writes per checkout — Req 10 perf).
# QUEUE_CONNECTION=database
QUEUE_CONNECTION=redis
SESSION_DRIVER=file
SESSION_LIFETIME=120

APACHE_THREADS=150
APACHE_AVG_REQUEST_MS=350
RATE_LIMIT_UTILIZATION=0.75
RATE_LIMIT_API_SHARE=0.20
RATE_LIMIT_AUTH_SHARE=0.20
RATE_LIMIT_CART_SHARE=0.35
RATE_LIMIT_CHECKOUT_SHARE=0.25

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
